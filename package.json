{
  "name": "if-scvm",
  "displayName": "IF SCVM",
  "description": "IF 智能卡脚本语言虚拟机",
  "version": "0.0.6",
  "publisher": "zelvin",
  "icon": "images/logo-v4.png",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "if-scvm.run",
        "title": "Run IF Script"
      },
      {
        "command": "if-scvm.selectReader",
        "title": "Select Card Reader"
      },
      {
        "command": "if-scvm.convertTelecom",
        "title": "Convert Telecom Script"
      },
      {
        "command": "if-scvm.convertFinance",
        "title": "Convert Finance Script"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "if-scvm.run",
          "group": "ifscvm@1",
          "when": "resourceExtname == .if"
        },
        {
          "command": "if-scvm.convertTelecom",
          "group": "ifscvm@2",
          "when": "resourceExtname == .if"
        },
        {
          "command": "if-scvm.convertFinance",
          "group": "ifscvm@3",
          "when": "resourceExtname == .if"
        }
      ],
      "editor/context": [
        {
          "command": "if-scvm.run",
          "when": "resourceExtname == .if",
          "group": "ifscvm@1"
        },
        {
          "command": "if-scvm.convertTelecom",
          "when": "resourceExtname == .if",
          "group": "ifscvm@2"
        },
        {
          "command": "if-scvm.convertFinance",
          "when": "resourceExtname == .if",
          "group": "ifscvm@3"
        }
      ]
    },
    "configuration": {
      "title": "IF Card VM",
      "properties": {
        "if-scvm.readerType": {
          "type": "integer",
          "default": 0,
          "enum": [
            0,
            1,
            2,
            3
          ],
          "enumDescriptions": [
            "PC/SC",
            "Q/SC",
            "SC/SC",
            "PT/SC"
          ],
          "description": "Card Reader Type"
        },
        "if-scvm.readerIndex": {
          "type": "number",
          "default": 0,
          "description": "Card Reader Index"
        },
        "if-scvm.protocol": {
          "type": "number",
          "default": 0,
          "enum": [
            0,
            1
          ],
          "enumDescriptions": [
            "ISO7816",
            "GP"
          ],
          "description": "Card protocol"
        },
        "if-scvm.dataFile": {
          "type": "string",
          "default": "",
          "description": "Perso data file"
        },
        "if-scvm.checkOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Check saved scripts when card_device_server supports --compile"
        }
      }
    },
    "languages": [
      {
        "id": "if",
        "aliases": [
          "IF Card",
          "if"
        ],
        "extensions": [
          ".if"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "if",
        "scopeName": "source.if",
        "path": "./syntaxes/if.tmLanguage.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zelviner/if-scvm.git"
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@vscode/vsce": "^3.9.1"
  }
}
