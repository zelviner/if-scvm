{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "IF Card",
  "scopeName": "source.if",
  "patterns": [
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#rst"
    },
    {
      "include": "#pps"
    },
    {
      "include": "#status-word"
    },
    {
      "include": "#apdu-string"
    }
  ],
  "repository": {
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.if",
          "match": "\\b(if|else|for|return|break|continue|switch|case|default|func|var|const|import|struct|true|false|null|as)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.if",
          "match": "\\b(int|int8|int16|int32|int64|string|bool|float|float32|float64|byte|bytes|array|map)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.if",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.if",
          "match": "\\b(0x[0-9A-Fa-f]+|\\d+)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.if",
          "begin": "\"",
          "end": "\""
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.if",
          "match": "//.*$"
        },
        {
          "name": "comment.block.if",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.if",
          "match": "->|\\+"
        }
      ]
    },
    "rst": {
      "patterns": [
        {
          "name": "support.function.rst.if",
          "match": "\\bRST\\b"
        }
      ]
    },
    "pps": {
      "patterns": [
        {
          "name": "support.function.pps.if",
          "match": "\\bPPS\\b"
        }
      ]
    },
    "apdu-string": {
      "patterns": [
        {
          "name": "string.quoted.apdu.if",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.numeric.hex.if",
              "match": "[0-9A-Fa-f]{2}"
            }
          ]
        }
      ]
    },
    "status-word": {
      "patterns": [
        {
          "name": "constant.language.status.if",
          "match": "\"\\*[0-9A-Fa-f]{4}\""
        }
      ]
    }
  }
}
